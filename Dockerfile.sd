# =============================================================================
# MirrAI SD Inpainting Image  (NO-MODEL BUILD)
# byoungj/sd-v1
#
# 이미지 크기: ~6GB (모델 없음, 코드 + pip만)
# 모델은 cold start 시 HF Hub에서 자동 다운로드
#   → RunPod Network Volume 마운트하면 재다운로드 없음
#
# 빌드 (Mac Apple Silicon → Linux amd64):
#   docker buildx build --platform linux/amd64 \
#     -f Dockerfile.sd \
#     -t byoungj/sd-v1 --push .
# =============================================================================

FROM pytorch/pytorch:2.4.1-cuda12.4-cudnn9-devel AS deps

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential git \
        libgl1 libglib2.0-0 libsm6 libxrender1 libxext6 \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ── requirements 파일 먼저 복사 (코드 변경 시 pip 캐시 재사용) ─────────────
COPY requirements-sd.txt ./

# ── Step A: 기본 패키지 (torch/torchvision/extra-index-url/opencv/xformers 제외) ──
RUN pip install --upgrade pip && \
    grep -vE "^torch|^torchvision|^--extra-index-url|^opencv|^xformers" \
        requirements-sd.txt > /tmp/req_base.txt && \
    pip install -r /tmp/req_base.txt

# ── Step B: torchvision CUDA 버전 강제 고정 ───────────────────────────────────
# SAM2 pip install이 의존성 해소 시 PyPI(CPU) torchvision으로 덮어쓸 수 있음.
# torchvision::nms C++ CUDA operator 누락 방지를 위해 명시적 재설치.
RUN pip install --force-reinstall --no-deps \
    "torchvision==0.19.1+cu124" \
    --extra-index-url https://download.pytorch.org/whl/cu124

# ── Step C: xformers ─────────────────────────────────────────────────────────
RUN pip install "xformers==0.0.27.post2"

# ── Step D: opencv headless (mediapipe 충돌 방지) ────────────────────────────
RUN pip install --force-reinstall "opencv-python-headless==4.10.0.84"

# =============================================================================
# Stage 2 – 런타임 (모델 없음 — cold start 시 다운로드)
# =============================================================================
FROM deps AS runtime

WORKDIR /app

# ── BiSeNet만 로컬 복사 (51MB, 작아서 OK) ─────────────────────────────────────
COPY pretrained_models/seg.pth pretrained_models/seg.pth

# ── 소스코드 복사 ─────────────────────────────────────────────────────────────
COPY entrypoint_sd.sh          entrypoint.sh
COPY handler_sd.py             ./
COPY pipeline_sd_inpainting.py ./
COPY runtime_download.py       ./
COPY utils/                    utils/
COPY models/face_parsing/      models/face_parsing/
COPY data/                     data/

# ── git 초기화 (entrypoint에서 git pull로 코드 최신화) ────────────────────────
# .py 파일 변경은 Docker 재빌드 없이 RunPod 재시작만으로 반영됨
RUN git init && \
    git remote add origin https://github.com/PracLee/hair_swap_model.git && \
    git config --global --add safe.directory /app

RUN chmod +x entrypoint.sh && \
    mkdir -p /app/output/runpod_inputs

ENV PYTHONPATH=/app \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    CUDA_HOME=/usr/local/cuda \
    PATH=/usr/local/cuda/bin:$PATH \
    LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH \
    ENABLE_SAM2=1

ENTRYPOINT ["./entrypoint.sh"]
